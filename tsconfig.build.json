{
	"extends": "@companion-module/tools/tsconfig/node22/recommended.json",
	"include": ["src/**/*.ts"],
	"exclude": ["node_modules/**", "src/**/*spec.ts", "src/**/__tests__/*", "src/**/__mocks__/*"],
	"compilerOptions": {
		"ignoreDeprecations": "6.0",
		"outDir": "./dist",
		"rootDir": "./src",
		"baseUrl": "./",
		"paths": {
			"*": ["./node_modules/*"]
		},
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"resolveJsonModule": true
	}
}
